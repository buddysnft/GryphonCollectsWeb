rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Users collection
    match /users/{userId} {
      // Anyone can read user profiles
      allow read: if true;
      
      // Users can create their own profile
      allow create: if isSignedIn() && isOwner(userId);
      
      // Users can only update their own profile
      // Admins can update any profile
      allow update: if isOwner(userId) || isAdmin();
      
      // Only admins can delete users
      allow delete: if isAdmin();
      
      // Subcollections
      match /orders/{orderId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false; // Orders created by Cloud Functions only
      }
      
      match /breakSpots/{spotId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false; // Break spots created by Cloud Functions only
      }
    }
    
    // Products collection
    match /products/{productId} {
      // Anyone can read products
      allow read: if true;
      
      // Only admins can write products
      allow create, update, delete: if isAdmin();
    }
    
    // Breaks collection
    match /breaks/{breakId} {
      // Anyone can read breaks
      allow read: if true;
      
      // Only admins can create/update/delete breaks
      allow create, update, delete: if isAdmin();
    }
    
    // Orders collection (root level)
    match /orders/{orderId} {
      // Users can read their own orders
      allow read: if isSignedIn() && 
                     resource.data.userId == request.auth.uid;
      
      // Admins can read all orders
      allow read: if isAdmin();
      
      // Orders created by Stripe webhooks only
      allow write: if false;
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      // Only admins can read/write notifications
      allow read, write: if isAdmin();
    }
    
    // Testimonials collection
    match /testimonials/{testimonialId} {
      // Anyone can read testimonials
      allow read: if true;
      
      // Only admins can write testimonials
      allow create, update, delete: if isAdmin();
    }
    
    // Newsletter collection
    match /newsletter/{subscriberId} {
      // Anyone can subscribe (create only)
      allow create: if request.resource.data.keys().hasAll(['email', 'subscribedAt', 'source', 'status']) &&
                       request.resource.data.email is string &&
                       request.resource.data.email.matches('.*@.*\\..*') &&
                       request.resource.data.status == 'active';
      
      // Only admins can read/update/delete subscribers
      allow read, update, delete: if isAdmin();
    }
    
    // Product Checklists collection
    match /productChecklists/{checklistId} {
      // Anyone can read checklists
      allow read: if true;
      
      // Only admins can write checklists
      allow create, update, delete: if isAdmin();
    }
    
    // Break Templates collection
    match /breakTemplates/{templateId} {
      // Only admins can read/write templates
      allow read, write: if isAdmin();
    }
    
    // Default: deny all access to any other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
